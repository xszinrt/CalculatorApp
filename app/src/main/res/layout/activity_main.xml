<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#1C1C1C">

    <TextView
        android:id="@+id/tv_result"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:text="0"
        android:textSize="64sp"
        android:textColor="#FFFFFF"
        android:gravity="end|bottom"
        android:padding="16dp"/>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:rowCount="5"
        android:columnCount="4">

        <Button android:id="@+id/btn_clear" android:text="C" android:layout_row="0" android:layout_column="0" android:layout_columnSpan="2" android:layout_margin="5dp" android:textSize="24sp" android:backgroundTint="#F44336"/>
        <Button android:id="@+id/btn_divide" android:text="÷" android:layout_row="0" android:layout_column="2" android:layout_margin="5dp" android:textSize="24sp" android:backgroundTint="#FF9800"/>
        <Button android:id="@+id/btn_multiply" android:text="×" android:layout_row="0" android:layout_column="3" android:layout_margin="5dp" android:textSize="24sp" android:backgroundTint="#FF9800"/>

        <Button android:id="@+id/btn_7" android:text="7" android:layout_row="1" android:layout_column="0" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_8" android:text="8" android:layout_row="1" android:layout_column="1" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_9" android:text="9" android:layout_row="1" android:layout_column="2" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_minus" android:text="-" android:layout_row="1" android:layout_column="3" android:layout_margin="5dp" android:textSize="24sp" android:backgroundTint="#FF9800"/>

        <Button android:id="@+id/btn_4" android:text="4" android:layout_row="2" android:layout_column="0" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_5" android:text="5" android:layout_row="2" android:layout_column="1" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_6" android:text="6" android:layout_row="2" android:layout_column="2" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_plus" android:text="+" android:layout_row="2" android:layout_column="3" android:layout_margin="5dp" android:textSize="24sp" android:backgroundTint="#FF9800"/>

        <Button android:id="@+id/btn_1" android:text="1" android:layout_row="3" android:layout_column="0" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_2" android:text="2" android:layout_row="3" android:layout_column="1" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_3" android:text="3" android:layout_row="3" android:layout_column="2" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_equal" android:text="=" android:layout_row="3" android:layout_column="3" android:layout_rowSpan="2" android:layout_margin="5dp" android:textSize="32sp" android:backgroundTint="#4CAF50"/>

        <Button android:id="@+id/btn_0" android:text="0" android:layout_row="4" android:layout_column="0" android:layout_columnSpan="2" android:layout_margin="5dp" android:textSize="24sp"/>
        <Button android:id="@+id/btn_decimal" android:text="." android:layout_row="4" android:layout_column="2" android:layout_margin="5dp" android:textSize="24sp"/>
    </GridLayout>
</LinearLayout>
